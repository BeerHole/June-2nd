# ── Stripe Keys ───────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── After running `node setup-stripe.js`, paste the Price IDs here ────────────
STRIPE_PRICE_COMPLETE_SET=price_...
STRIPE_PRICE_EXTRA_BAGS=price_...
STRIPE_PRICE_MERCH=price_...

# ── Webhook secret (from `stripe listen` or Stripe Dashboard) ─────────────────
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Your site's base URL ──────────────────────────────────────────────────────
DOMAIN=http://localhost:3000
