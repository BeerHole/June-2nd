<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BeerHole</title>
<link href="https://fonts.googleapis.com/css2?family=Black+Han+Sans&family=Bebas+Neue&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --amber: #EF9F27;
    --amber-dark: #BA7517;
    --amber-light: #FAEEDA;
    --green: #639922;
    --green-dark: #3B6D11;
    --cream: #FFF8EC;
    --brown: #2C1A06;
    --brown-mid: #5C3A14;
    --text: #1a1006;
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--text);
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; justify-content: space-between; align-items: center;
    padding: 1rem 2.5rem;
    background: rgba(255,248,236,0.92);
    backdrop-filter: blur(8px);
    border-bottom: 2px solid var(--amber);
  }
  .nav-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    letter-spacing: 0.06em;
    color: var(--brown);
  }
  .nav-logo span { color: var(--amber); }
  .nav-cta {
    background: var(--amber);
    color: var(--brown);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.55rem 1.4rem;
    border-radius: 100px;
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: background 0.2s, transform 0.15s;
    border: none; cursor: pointer;
  }
  .nav-cta:hover { background: var(--amber-dark); transform: scale(1.04); }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 8rem 2rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .hero-bg-dots {
    position: absolute; inset: 0; z-index: 0;
    background-image: radial-gradient(circle, var(--amber) 1.5px, transparent 1.5px);
    background-size: 36px 36px;
    opacity: 0.18;
  }

  .hero-badge {
    display: inline-block;
    background: var(--green);
    color: #EAF3DE;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0.35rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
    position: relative; z-index: 1;
  }

  .hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(5rem, 14vw, 11rem);
    line-height: 0.9;
    letter-spacing: 0.02em;
    color: var(--brown);
    position: relative; z-index: 1;
  }
  .hero-title span { color: var(--amber); }

  .hero-sub {
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    color: var(--brown-mid);
    max-width: 520px;
    margin: 1.5rem auto 0;
    line-height: 1.6;
    position: relative; z-index: 1;
  }

  .hero-ctas {
    display: flex; gap: 1rem; flex-wrap: wrap;
    justify-content: center;
    margin-top: 2.5rem;
    position: relative; z-index: 1;
  }
  .btn-primary {
    background: var(--brown);
    color: var(--amber-light);
    font-weight: 700;
    font-size: 1rem;
    padding: 0.85rem 2.2rem;
    border-radius: 100px;
    text-decoration: none;
    letter-spacing: 0.03em;
    border: none; cursor: pointer;
    transition: transform 0.15s, background 0.2s;
  }
  .btn-primary:hover { background: #1a0e03; transform: translateY(-2px); }
  .btn-secondary {
    background: transparent;
    color: var(--brown);
    font-weight: 700;
    font-size: 1rem;
    padding: 0.85rem 2.2rem;
    border-radius: 100px;
    border: 2.5px solid var(--brown);
    cursor: pointer;
    transition: transform 0.15s, background 0.2s;
  }
  .btn-secondary:hover { background: rgba(44,26,6,0.08); transform: translateY(-2px); }

  /* BOARD ILLUSTRATION */
  .board-wrap {
    position: relative; z-index: 1;
    margin-top: 3rem;
  }
  .board-label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--brown-mid);
    margin-bottom: 0.75rem;
    opacity: 0.6;
  }

  /* DIVIDER */
  .divider {
    text-align: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.1rem;
    letter-spacing: 0.25em;
    color: var(--amber);
    padding: 0.5rem 0;
  }

  /* HOW IT WORKS */
  .section {
    padding: 5rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 0.95rem;
    letter-spacing: 0.25em;
    color: var(--amber-dark);
    margin-bottom: 0.5rem;
  }
  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    line-height: 1;
    color: var(--brown);
    margin-bottom: 3rem;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
  }
  .step {
    background: white;
    border-radius: 20px;
    padding: 2rem 1.5rem;
    border: 2px solid rgba(44,26,6,0.09);
    position: relative;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .step:hover { transform: translateY(-5px); box-shadow: 0 12px 32px rgba(44,26,6,0.1); }
  .step-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 4rem;
    color: var(--amber);
    line-height: 1;
    margin-bottom: 0.5rem;
    opacity: 0.8;
  }
  .step h3 {
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--brown);
  }
  .step p {
    font-size: 0.92rem;
    color: var(--brown-mid);
    line-height: 1.6;
  }

  /* SCORING */
  .scoring-section {
    background: var(--brown);
    padding: 5rem 2rem;
    color: var(--amber-light);
    overflow: hidden;
    position: relative;
  }
  .scoring-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media(max-width: 700px) { .scoring-inner { grid-template-columns: 1fr; } }

  .scoring-section .section-label { color: var(--amber); }
  .scoring-section .section-title { color: white; margin-bottom: 2rem; }
  .score-list { list-style: none; display: flex; flex-direction: column; gap: 1rem; }
  .score-item {
    display: flex; align-items: flex-start; gap: 1rem;
    padding: 1rem 1.25rem;
    background: rgba(255,255,255,0.06);
    border-radius: 14px;
    border-left: 4px solid var(--amber);
  }
  .score-pts {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    color: var(--amber);
    min-width: 56px;
    line-height: 1;
  }
  .score-desc strong {
    display: block;
    font-weight: 700;
    font-size: 0.95rem;
    color: white;
    margin-bottom: 0.2rem;
  }
  .score-desc span { font-size: 0.85rem; color: rgba(255,248,236,0.6); }

  /* HOLE GRID VISUAL */
  .hole-grid-wrap {
    display: flex; justify-content: center; align-items: center;
  }

  /* CTA SECTION */
  .cta-section {
    padding: 6rem 2rem;
    text-align: center;
    background: var(--amber-light);
    position: relative;
    overflow: hidden;
  }
  .cta-section::before {
    content: 'BEERHOLE';
    position: absolute;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22vw;
    color: rgba(239,159,39,0.12);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    pointer-events: none;
    letter-spacing: 0.06em;
  }
  .cta-section .section-title { position: relative; z-index:1; }
  .cta-section p { position: relative; z-index:1; font-size: 1.1rem; color: var(--brown-mid); margin-bottom: 2rem; max-width: 480px; margin-left:auto; margin-right:auto;}
  .cta-section .btn-primary { position: relative; z-index:1; }

  /* FOOTER */
  footer {
    background: var(--brown);
    color: rgba(255,248,236,0.4);
    text-align: center;
    padding: 2rem;
    font-size: 0.82rem;
    letter-spacing: 0.05em;
  }
  footer strong { color: var(--amber); font-family: 'Bebas Neue', sans-serif; font-size: 1rem; letter-spacing: 0.12em; }

  /* ANIMATION */
  @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
  .board-float { animation: float 4s ease-in-out infinite; }
  @keyframes fadein { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }
  .hero-badge, .hero-title, .hero-sub, .hero-ctas, .board-wrap { animation: fadein 0.7s ease both; }
  .hero-badge { animation-delay: 0.1s; }
  .hero-title { animation-delay: 0.25s; }
  .hero-sub { animation-delay: 0.4s; }
  .hero-ctas { animation-delay: 0.55s; }
  .board-wrap { animation-delay: 0.7s; }
</style>
</head>
<body>

<nav>
  <div class="nav-logo">Beer<span>Hole</span></div>
  <button class="nav-cta" onclick="document.getElementById('cta').scrollIntoView({behavior:'smooth'})">Get Yours</button>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg-dots"></div>
  <div class="hero-badge">The Ultimate Lawn Game</div>
  <h1 class="hero-title">Beer<span>Hole</span></h1>
  <p class="hero-sub">Beer pong meets cornhole. Nine holes. Two teams. Zero mercy. The backyard just got a whole lot more interesting.</p>
  <div class="hero-ctas">
    <button class="btn-primary" onclick="document.getElementById('cta').scrollIntoView({behavior:'smooth'})">Shop Now</button>
    <button class="btn-secondary" onclick="document.getElementById('how').scrollIntoView({behavior:'smooth'})">How to Play</button>
  </div>

  <div class="board-wrap board-float">
    <p class="board-label">The Board</p>
    <svg width="300" height="190" viewBox="0 0 300 190" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Board body -->
      <rect x="10" y="30" width="280" height="150" rx="16" fill="#5C3A14"/>
      <rect x="10" y="30" width="280" height="150" rx="16" stroke="#EF9F27" stroke-width="3"/>
      <!-- Wood grain lines -->
      <line x1="30" y1="30" x2="30" y2="180" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
      <line x1="80" y1="30" x2="80" y2="180" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
      <line x1="150" y1="30" x2="150" y2="180" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
      <line x1="220" y1="30" x2="220" y2="180" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
      <line x1="270" y1="30" x2="270" y2="180" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
      <!-- 9 holes: 3x3 grid -->
      <!-- Row 1 -->
      <circle cx="85" cy="75" r="20" fill="#1a0e03" stroke="#EF9F27" stroke-width="2"/>
      <circle cx="150" cy="75" r="20" fill="#1a0e03" stroke="#EF9F27" stroke-width="2"/>
      <circle cx="215" cy="75" r="20" fill="#1a0e03" stroke="#EF9F27" stroke-width="2"/>
      <!-- Row 2 -->
      <circle cx="85" cy="130" r="20" fill="#1a0e03" stroke="#EF9F27" stroke-width="2"/>
      <circle cx="150" cy="130" r="20" fill="#1a0e03" stroke="#EF9F27" stroke-width="2"/>
      <circle cx="215" cy="130" r="20" fill="#1a0e03" stroke="#EF9F27" stroke-width="2"/>
      <!-- Row 3 ... only 3 holes per row = 9 total, but let's do 3 rows -->
      <!-- Leg left -->
      <rect x="30" y="175" width="18" height="14" rx="4" fill="#3B2209"/>
      <!-- Leg right -->
      <rect x="252" y="175" width="18" height="14" rx="4" fill="#3B2209"/>
      <!-- Label -->
      <text x="150" y="20" text-anchor="middle" font-family="'Bebas Neue', sans-serif" font-size="15" fill="#EF9F27" letter-spacing="3">BEERHOLE</text>
    </svg>
  </div>
</section>

<div class="divider">✦ &nbsp; DRINK • AIM • REPEAT &nbsp; ✦</div>

<!-- HOW IT WORKS -->
<section class="section" id="how">
  <p class="section-label">How to Play</p>
  <h2 class="section-title">Simple Rules.<br>Serious Fun.</h2>
  <div class="steps">
    <div class="step">
      <div class="step-num">01</div>
      <h3>Set Up the Board</h3>
      <p>Place two BeerHole boards 27 feet apart (or closer for casual play). Each board has 9 numbered holes — just like beer pong cups, but better.</p>
    </div>
    <div class="step">
      <div class="step-num">02</div>
      <h3>Fill Your Drinks</h3>
      <p>Each hole on the board corresponds to a drink. Land the bag, your opponent drinks. Sink it in the center hole? That's the money shot.</p>
    </div>
    <div class="step">
      <div class="step-num">03</div>
      <h3>Toss & Score</h3>
      <p>Teams take turns tossing bags. Different holes = different points and drink penalties. First team to 21 wins.</p>
    </div>
    <div class="step">
      <div class="step-num">04</div>
      <h3>Redemption Round</h3>
      <p>Losing team gets a redemption toss to tie it up — just like beer pong. The chaos doesn't stop until the last bag drops.</p>
    </div>
  </div>
</section>

<!-- SCORING -->
<section class="scoring-section">
  <div class="scoring-inner">
    <div>
      <p class="section-label">Scoring System</p>
      <h2 class="section-title">Every Hole<br>Has a Price.</h2>
      <ul class="score-list">
        <li class="score-item">
          <div class="score-pts">3</div>
          <div class="score-desc">
            <strong>Center Hole — The BeerHole</strong>
            <span>3 points + opponent finishes their drink</span>
          </div>
        </li>
        <li class="score-item">
          <div class="score-pts">2</div>
          <div class="score-desc">
            <strong>Corner Holes</strong>
            <span>2 points + opponent takes 2 sips</span>
          </div>
        </li>
        <li class="score-item">
          <div class="score-pts">1</div>
          <div class="score-desc">
            <strong>Edge Holes</strong>
            <span>1 point + opponent takes 1 sip</span>
          </div>
        </li>
        <li class="score-item">
          <div class="score-pts">🎯</div>
          <div class="score-desc">
            <strong>Board (no hole) — Cornhole Rules</strong>
            <span>1 point, no drink</span>
          </div>
        </li>
      </ul>
    </div>
    <div class="hole-grid-wrap">
      <svg width="240" height="240" viewBox="0 0 240 240" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="4" y="4" width="232" height="232" rx="18" fill="#3B2209" stroke="#EF9F27" stroke-width="2.5"/>
        <!-- Corner holes (2pts) -->
        <circle cx="56" cy="56" r="28" fill="#1a0e03" stroke="#EF9F27" stroke-width="2"/>
        <text x="56" y="61" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="16" fill="#EF9F27">2PT</text>
        <circle cx="184" cy="56" r="28" fill="#1a0e03" stroke="#EF9F27" stroke-width="2"/>
        <text x="184" y="61" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="16" fill="#EF9F27">2PT</text>
        <circle cx="56" cy="184" r="28" fill="#1a0e03" stroke="#EF9F27" stroke-width="2"/>
        <text x="56" y="189" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="16" fill="#EF9F27">2PT</text>
        <circle cx="184" cy="184" r="28" fill="#1a0e03" stroke="#EF9F27" stroke-width="2"/>
        <text x="184" y="189" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="16" fill="#EF9F27">2PT</text>
        <!-- Edge holes (1pt) -->
        <circle cx="120" cy="56" r="22" fill="#1a0e03" stroke="rgba(239,159,39,0.5)" stroke-width="1.5"/>
        <text x="120" y="61" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="14" fill="rgba(239,159,39,0.7)">1PT</text>
        <circle cx="120" cy="184" r="22" fill="#1a0e03" stroke="rgba(239,159,39,0.5)" stroke-width="1.5"/>
        <text x="120" y="189" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="14" fill="rgba(239,159,39,0.7)">1PT</text>
        <circle cx="56" cy="120" r="22" fill="#1a0e03" stroke="rgba(239,159,39,0.5)" stroke-width="1.5"/>
        <text x="56" y="125" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="14" fill="rgba(239,159,39,0.7)">1PT</text>
        <circle cx="184" cy="120" r="22" fill="#1a0e03" stroke="rgba(239,159,39,0.5)" stroke-width="1.5"/>
        <text x="184" y="125" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="14" fill="rgba(239,159,39,0.7)">1PT</text>
        <!-- Center hole (3pts) -->
        <circle cx="120" cy="120" r="30" fill="#1a0e03" stroke="#EF9F27" stroke-width="3"/>
        <text x="120" y="115" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="15" fill="#EF9F27">3PT</text>
        <text x="120" y="132" text-anchor="middle" font-family="'DM Sans',sans-serif" font-size="9" fill="rgba(239,159,39,0.7)" font-weight="700" letter-spacing="1">BEERHOLE</text>
      </svg>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section" id="cta">
  <h2 class="section-title">Ready to Play?</h2>
  <p>Grab a BeerHole set and make your next backyard hang legendary. Ships in 3–5 days. Built to last every summer.</p>
  <button class="btn-primary" style="font-size:1.1rem; padding: 1rem 3rem;">Order Now — $79</button>
</section>

<footer>
  <strong>BeerHole</strong><br>
  <span>Drink responsibly. Play relentlessly. &copy; 2026 BeerHole Co.</span>
</footer>

</body>
</html>
