<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Permanent+Marker&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --yellow:#FFE600;
  --orange:#FF5C00;
  --red:#E8001D;
  --black:#0A0A0A;
  --white:#FAFAF5;
  --pink:#FF2D78;
}
body{font-family:'DM Sans',sans-serif;background:var(--black);color:var(--white);overflow-x:hidden;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;justify-content:space-between;align-items:center;padding:0.9rem 2rem;background:var(--black);border-bottom:3px solid var(--yellow);}
.logo{font-family:'Anton',sans-serif;font-size:1.8rem;letter-spacing:0.06em;color:var(--yellow);text-transform:uppercase;}
.logo span{color:var(--orange);}
.nav-btn{background:var(--yellow);color:var(--black);font-weight:700;font-size:0.85rem;padding:0.5rem 1.3rem;border-radius:6px;border:none;cursor:pointer;letter-spacing:0.06em;text-transform:uppercase;transition:transform 0.15s,background 0.15s;}
.nav-btn:hover{background:var(--orange);color:var(--white);transform:scale(1.05);}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:7rem 1.5rem 4rem;position:relative;overflow:hidden;}

/* animated stripe bg */
.hero-stripes{position:absolute;inset:0;z-index:0;
  background:repeating-linear-gradient(
    -55deg,
    transparent,transparent 40px,
    rgba(255,230,0,0.04) 40px,rgba(255,230,0,0.04) 80px
  );
}
.confetti-dot{position:absolute;border-radius:50%;animation:drift linear infinite;}
@keyframes drift{0%{transform:translateY(-40px) rotate(0deg);opacity:1;}100%{transform:translateY(110vh) rotate(720deg);opacity:0;}}

.hero-eyebrow{font-family:'Permanent Marker',cursive;font-size:1.1rem;color:var(--orange);margin-bottom:0.75rem;position:relative;z-index:1;transform:rotate(-2deg);display:inline-block;}
.hero-title{font-family:'Anton',sans-serif;font-size:clamp(5.5rem,18vw,13rem);line-height:0.88;letter-spacing:0.01em;text-transform:uppercase;position:relative;z-index:1;}
.hero-title .t1{color:var(--white);}
.hero-title .t2{color:var(--yellow);-webkit-text-stroke:3px var(--yellow);display:block;}
.hero-sub{font-size:clamp(1rem,2.2vw,1.25rem);color:rgba(250,250,245,0.65);max-width:480px;margin:1.4rem auto 0;line-height:1.55;position:relative;z-index:1;}
.hero-sub strong{color:var(--yellow);}

.hero-ctas{display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;margin-top:2.2rem;position:relative;z-index:1;}
.btn-primary{background:var(--yellow);color:var(--black);font-weight:700;font-size:1rem;padding:0.9rem 2.4rem;border-radius:8px;border:none;cursor:pointer;letter-spacing:0.06em;text-transform:uppercase;transition:transform 0.15s,background 0.15s;}
.btn-primary:hover{background:var(--orange);color:var(--white);transform:translateY(-3px);}
.btn-ghost{background:transparent;color:var(--white);font-weight:700;font-size:1rem;padding:0.9rem 2.4rem;border-radius:8px;border:2px solid rgba(255,255,255,0.25);cursor:pointer;letter-spacing:0.06em;text-transform:uppercase;transition:transform 0.15s,border-color 0.15s;}
.btn-ghost:hover{border-color:var(--yellow);color:var(--yellow);transform:translateY(-3px);}

/* SCROLL TICKER */
.ticker{background:var(--yellow);padding:0.65rem 0;overflow:hidden;white-space:nowrap;}
.ticker-inner{display:inline-flex;animation:tick 18s linear infinite;}
.ticker-item{font-family:'Anton',sans-serif;font-size:1rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--black);padding:0 2rem;}
.ticker-item span{color:var(--orange);margin-right:2rem;}
@keyframes tick{from{transform:translateX(0);}to{transform:translateX(-50%);}}

/* SOCIAL PROOF */
.proof{display:flex;justify-content:center;gap:2.5rem;flex-wrap:wrap;padding:3.5rem 2rem;border-bottom:1px solid rgba(255,255,255,0.08);}
.proof-stat{text-align:center;}
.proof-num{font-family:'Anton',sans-serif;font-size:3rem;color:var(--yellow);line-height:1;}
.proof-label{font-size:0.8rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.45);margin-top:0.25rem;}

/* HOW TO PLAY */
.section{padding:5rem 2rem;max-width:1080px;margin:0 auto;}
.tag{display:inline-block;font-family:'Permanent Marker',cursive;font-size:0.95rem;color:var(--orange);margin-bottom:0.5rem;transform:rotate(-1.5deg);}
.section-title{font-family:'Anton',sans-serif;font-size:clamp(2.5rem,6vw,4.5rem);text-transform:uppercase;color:var(--white);line-height:1;margin-bottom:2.5rem;}
.section-title span{color:var(--yellow);}

.steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:1.5rem;}
.step{background:#141414;border-radius:12px;padding:1.75rem 1.5rem;border:1px solid rgba(255,255,255,0.07);position:relative;overflow:hidden;transition:transform 0.2s,border-color 0.2s;}
.step::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--yellow);}
.step:hover{transform:translateY(-5px);border-color:rgba(255,230,0,0.3);}
.step-num{font-family:'Anton',sans-serif;font-size:3.5rem;color:rgba(255,230,0,0.12);line-height:1;position:absolute;top:1rem;right:1rem;}
.step h3{font-weight:700;font-size:1rem;margin-bottom:0.5rem;color:var(--white);text-transform:uppercase;letter-spacing:0.05em;}
.step p{font-size:0.88rem;color:rgba(255,255,255,0.5);line-height:1.6;}

/* SCORING */
.scoring{background:#111;border-top:1px solid rgba(255,255,255,0.07);border-bottom:1px solid rgba(255,255,255,0.07);padding:5rem 2rem;}
.scoring-inner{max-width:1080px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;}
@media(max-width:680px){.scoring-inner{grid-template-columns:1fr;}}

.score-list{list-style:none;display:flex;flex-direction:column;gap:0.85rem;margin-top:2rem;}
.score-item{display:flex;align-items:center;gap:1rem;padding:1rem 1.25rem;background:#1a1a1a;border-radius:10px;border-left:4px solid var(--yellow);transition:background 0.2s;}
.score-item:hover{background:#222;}
.score-pts{font-family:'Anton',sans-serif;font-size:2.2rem;color:var(--yellow);min-width:52px;line-height:1;}
.score-desc strong{display:block;font-weight:700;font-size:0.92rem;color:var(--white);}
.score-desc span{font-size:0.8rem;color:rgba(255,255,255,0.4);}

/* HOLE GRID */
.grid-wrap{display:flex;justify-content:center;}

/* CTA */
.cta-block{background:var(--yellow);padding:6rem 2rem;text-align:center;position:relative;overflow:hidden;}
.cta-block::before{content:'BEERHOLE';position:absolute;font-family:'Anton',sans-serif;font-size:20vw;color:rgba(0,0,0,0.07);top:50%;left:50%;transform:translate(-50%,-50%);white-space:nowrap;pointer-events:none;letter-spacing:0.04em;}
.cta-block h2{font-family:'Anton',sans-serif;font-size:clamp(3rem,8vw,6rem);text-transform:uppercase;color:var(--black);line-height:1;position:relative;z-index:1;margin-bottom:0.75rem;}
.cta-block p{font-size:1.1rem;color:rgba(0,0,0,0.6);max-width:440px;margin:0 auto 2rem;position:relative;z-index:1;}
.btn-dark{background:var(--black);color:var(--yellow);font-weight:700;font-size:1.1rem;padding:1rem 3rem;border-radius:8px;border:none;cursor:pointer;letter-spacing:0.08em;text-transform:uppercase;position:relative;z-index:1;transition:transform 0.15s,background 0.15s;}
.btn-dark:hover{background:#1a1a1a;transform:translateY(-3px);}
.price-tag{font-family:'Anton',sans-serif;font-size:1.2rem;color:rgba(0,0,0,0.4);position:relative;z-index:1;margin-top:1rem;letter-spacing:0.05em;}

/* FOOTER */
footer{background:#050505;text-align:center;padding:2rem;font-size:0.8rem;color:rgba(255,255,255,0.2);border-top:1px solid rgba(255,255,255,0.06);}
footer strong{font-family:'Anton',sans-serif;font-size:1rem;letter-spacing:0.1em;color:var(--yellow);}

/* ANIMATIONS */
@keyframes popIn{from{opacity:0;transform:scale(0.88) translateY(20px);}to{opacity:1;transform:scale(1) translateY(0);}}
.hero>*{animation:popIn 0.55s ease both;}
.hero-eyebrow{animation-delay:0.05s;}
.hero-title{animation-delay:0.15s;}
.hero-sub{animation-delay:0.28s;}
.hero-ctas{animation-delay:0.4s;}
</style>
</head>
<body>

<nav>
  <div class="logo">Beer<span>Hole</span></div>
